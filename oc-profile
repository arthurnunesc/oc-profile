#!/usr/bin/env bash
set -euo pipefail

AUTH_DIR="${HOME}/.local/share/opencode"
AUTH_FILE="${AUTH_DIR}/auth.json"
PROFILES_DIR="${AUTH_DIR}/profiles"

# ── Colors ────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Helpers ───────────────────────────────────────────────

die() { echo -e "${RED}error:${RESET} $1" >&2; exit 1; }
info() { echo -e "${CYAN}$1${RESET}"; }
success() { echo -e "${GREEN}$1${RESET}"; }
warn() { echo -e "${YELLOW}$1${RESET}"; }

ensure_profiles_dir() {
  mkdir -p "${PROFILES_DIR}"
}

# Validate profile name: alphanumeric, hyphens, underscores
validate_name() {
  local name="$1"
  if [[ -z "${name}" ]]; then
    die "profile name cannot be empty."
  fi
  if [[ ! "${name}" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    die "invalid profile name '${name}'. Use only letters, numbers, hyphens, and underscores."
  fi
}

profile_exists() {
  [[ -f "${PROFILES_DIR}/$1.json" ]]
}

profile_count() {
  ensure_profiles_dir
  find "${PROFILES_DIR}" -maxdepth 1 -name '*.json' -type f 2>/dev/null | wc -l | tr -d ' '
}

# Returns the active profile name, or "" if none/dangling
active_profile() {
  if [[ -L "${AUTH_FILE}" ]]; then
    local target
    target="$(readlink "${AUTH_FILE}" 2>/dev/null || true)"
    if [[ -n "${target}" && -f "${target}" ]]; then
      basename "${target}" .json
    fi
  fi
}

warn_if_opencode_running() {
  if pgrep -x opencode >/dev/null 2>&1; then
    warn "warning: opencode appears to be running. Restart it after switching."
  fi
}

# ── Commands ──────────────────────────────────────────────

cmd_make() {
  local name=""
  local set_current=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --current) set_current=true; shift ;;
      -*) die "unknown flag '$1'. Usage: opencode-profile make <name> [--current]" ;;
      *) name="$1"; shift ;;
    esac
  done

  [[ -z "${name}" ]] && die "usage: opencode-profile make <name> [--current]"
  validate_name "${name}"
  ensure_profiles_dir

  if profile_exists "${name}"; then
    die "profile '${name}' already exists. Delete it first or choose another name."
  fi

  if ${set_current}; then
    # Copy current auth.json into the profile
    if [[ -L "${AUTH_FILE}" ]]; then
      local resolved
      resolved="$(readlink "${AUTH_FILE}")"
      if [[ ! -f "${resolved}" ]]; then
        die "auth.json symlink is dangling (points to '${resolved}'). Run /connect in opencode first."
      fi
      cp "${resolved}" "${PROFILES_DIR}/${name}.json"
    elif [[ -f "${AUTH_FILE}" ]]; then
      cp "${AUTH_FILE}" "${PROFILES_DIR}/${name}.json"
    else
      die "no auth.json found at ${AUTH_FILE}. Run /connect in opencode first."
    fi

    # Replace auth.json with symlink to this profile
    if [[ -f "${AUTH_FILE}" && ! -L "${AUTH_FILE}" ]]; then
      rm "${AUTH_FILE}"
    fi
    ln -sf "${PROFILES_DIR}/${name}.json" "${AUTH_FILE}"
    success "created profile '${name}' from current auth and set as active."
  else
    # Create an empty placeholder profile
    echo '{}' > "${PROFILES_DIR}/${name}.json"
    success "created empty profile '${name}'."
    info "run /connect in opencode, then 'opencode-profile make ${name} --current' or switch to it and /connect."
  fi
}

cmd_switch() {
  local name="${1:-}"
  [[ -z "${name}" ]] && die "usage: opencode-profile switch <name>"
  validate_name "${name}"

  if ! profile_exists "${name}"; then
    die "profile '${name}' does not exist. Run 'opencode-profile list' to see available profiles."
  fi

  local current
  current="$(active_profile)"
  if [[ "${current}" == "${name}" ]]; then
    info "already on profile '${name}'."
    return
  fi

  warn_if_opencode_running

  # If auth.json is a regular file (first time switching), remove it
  if [[ -f "${AUTH_FILE}" && ! -L "${AUTH_FILE}" ]]; then
    # Safety: back it up in case user forgot to save it
    local backup="${AUTH_DIR}/auth.json.backup"
    cp "${AUTH_FILE}" "${backup}"
    warn "backed up existing auth.json to ${backup}"
    rm "${AUTH_FILE}"
  fi

  ln -sf "${PROFILES_DIR}/${name}.json" "${AUTH_FILE}"
  success "switched to '${name}'. Restart opencode to apply."
}

cmd_list() {
  ensure_profiles_dir
  local profiles=()
  while IFS= read -r f; do
    profiles+=("$(basename "$f" .json)")
  done < <(find "${PROFILES_DIR}" -maxdepth 1 -name '*.json' -type f 2>/dev/null | sort)

  if [[ ${#profiles[@]} -eq 0 ]]; then
    info "no profiles saved yet."
    echo ""
    echo "  opencode-profile make <name> --current    save current auth as a profile"
    return
  fi

  local current
  current="$(active_profile)"

  echo ""
  echo -e "${BOLD}OpenAI profiles:${RESET}"
  echo ""
  for p in "${profiles[@]}"; do
    if [[ "${p}" == "${current}" ]]; then
      echo -e "  ${GREEN}* ${p}${RESET} ${DIM}(active)${RESET}"
    else
      echo -e "    ${p}"
    fi
  done
  echo ""
}

cmd_delete() {
  local name="${1:-}"
  [[ -z "${name}" ]] && die "usage: opencode-profile delete <name>"
  validate_name "${name}"

  if ! profile_exists "${name}"; then
    die "profile '${name}' does not exist."
  fi

  local count
  count="$(profile_count)"
  if [[ "${count}" -le 1 ]]; then
    die "cannot delete the last profile."
  fi

  local current
  current="$(active_profile)"
  if [[ "${current}" == "${name}" ]]; then
    die "cannot delete the active profile. Switch to another profile first."
  fi

  rm "${PROFILES_DIR}/${name}.json"
  success "deleted profile '${name}'."
}

cmd_rename() {
  local old="${1:-}"
  local new="${2:-}"
  [[ -z "${old}" || -z "${new}" ]] && die "usage: opencode-profile rename <old-name> <new-name>"
  validate_name "${old}"
  validate_name "${new}"

  if ! profile_exists "${old}"; then
    die "profile '${old}' does not exist."
  fi
  if profile_exists "${new}"; then
    die "profile '${new}' already exists."
  fi

  mv "${PROFILES_DIR}/${old}.json" "${PROFILES_DIR}/${new}.json"

  # If the renamed profile was active, update the symlink
  local current
  current="$(active_profile)"
  if [[ "${current}" == "${old}" || -z "${current}" ]]; then
    # Re-check: symlink might now be dangling after the rename
    if [[ -L "${AUTH_FILE}" ]]; then
      ln -sf "${PROFILES_DIR}/${new}.json" "${AUTH_FILE}"
    fi
  fi

  success "renamed '${old}' -> '${new}'."
}

cmd_which() {
  local current
  current="$(active_profile)"
  if [[ -n "${current}" ]]; then
    echo "${current}"
  elif [[ -f "${AUTH_FILE}" && ! -L "${AUTH_FILE}" ]]; then
    info "auth.json is a regular file (no profile active)."
    info "run 'opencode-profile make <name> --current' to save it as a profile."
  else
    die "no active profile found."
  fi
}

cmd_help() {
  echo ""
  echo -e "${BOLD}opencode-profile${RESET} — manage OpenAI auth profiles for OpenCode"
  echo ""
  echo -e "${BOLD}USAGE${RESET}"
  echo "  opencode-profile <command> [args]"
  echo ""
  echo -e "${BOLD}COMMANDS${RESET}"
  echo "  make <name> [--current]    Create a profile from current auth.json (--current)"
  echo "                             or an empty placeholder (without --current)"
  echo "  switch <name>              Switch to a different profile"
  echo "  list                       List all profiles"
  echo "  which                      Show the active profile name"
  echo "  rename <old> <new>         Rename a profile"
  echo "  delete <name>              Delete a profile (not the last or active one)"
  echo "  help                       Show this help"
  echo ""
  echo -e "${BOLD}SETUP${RESET}"
  echo "  1. /connect in opencode with account A"
  echo "  2. opencode-profile make work --current"
  echo "  3. /connect in opencode with account B"
  echo "  4. opencode-profile make personal --current"
  echo "  5. opencode-profile switch work"
  echo "  6. restart opencode"
  echo ""
  echo -e "${BOLD}FILES${RESET}"
  echo "  ${AUTH_FILE}        (symlink to active profile)"
  echo "  ${PROFILES_DIR}/   (saved profiles)"
  echo ""
}

# ── Main ──────────────────────────────────────────────────

cmd="${1:-help}"
shift || true

case "${cmd}" in
  make)    cmd_make "$@" ;;
  switch)  cmd_switch "$@" ;;
  list|ls) cmd_list ;;
  delete|rm) cmd_delete "$@" ;;
  rename|mv) cmd_rename "$@" ;;
  which)   cmd_which ;;
  help|--help|-h) cmd_help ;;
  *) die "unknown command '${cmd}'. Run 'opencode-profile help' for usage." ;;
esac
